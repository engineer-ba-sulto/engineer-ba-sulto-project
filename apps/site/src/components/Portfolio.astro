---
import { projects } from "../contents/portfolio.ts";
import ProjectCard from "./ui/ProjectCard.astro";
---

<main class="w-full max-w-[1800px] px-4 md:px-8 lg:px-12 py-16">
  <div class="text-center mb-12" data-animate="portfolio-header">
    <h2 class="text-3xl font-bold text-[#1f3e2d] mb-2">
      My Portfolio
    </h2>
    <p class="text-[#2d5941] font-medium">
      Showcasing my web and mobile applications
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
    {projects.map((project) => (
      <ProjectCard project={project} />
    ))}
  </div>
</main>
