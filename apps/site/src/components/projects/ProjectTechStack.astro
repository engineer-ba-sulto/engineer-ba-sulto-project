---
import type { Project } from "../../types/project";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<section id="tech-stack" class="max-w-7xl mx-auto px-8 py-10">
  <div class="bg-[#e0f0e5] rounded-3xl p-10 flex flex-col md:flex-row items-center gap-12">
    <div class="md:w-1/3">
      <h2 class="text-2xl font-bold mb-3">Built With</h2>
    </div>
    <div class="md:w-2/3 flex flex-wrap gap-4">
      {(project.detail?.techStack || project.tags).map((tech) => (
        <div class="bg-white px-5 py-3 rounded-xl flex items-center gap-3 font-medium shadow-sm border border-gray-100">
          <div class="w-2 h-2 bg-[#31a376] rounded-full"></div>
          {tech}
        </div>
      ))}
    </div>
  </div>
</section>
